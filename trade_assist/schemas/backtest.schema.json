{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "trade_assist backtest config",
  "type": "object",
  "required": ["data", "portfolio"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "data": {
      "type": "object",
      "required": ["tickers"],
      "additionalProperties": false,
      "properties": {
        "tickers": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "index_ticker": {"type": "string", "default": "SPY"},
        "regime_tickers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "period": {"type": "string", "default": "5y"},
        "interval": {"type": "string", "default": "1d"},
        "use_cache": {"type": "boolean", "default": false},
        "cache_dir": {"type": "string", "default": ".cache/market_data"},
        "cache_ttl_hours": {
          "oneOf": [
            {"type": "number", "exclusiveMinimum": 0},
            {"type": "null"}
          ],
          "default": 24
        },
        "force_refresh": {"type": "boolean", "default": false}
      }
    },
    "policy_path": {"type": "string"},
    "policy": {"$ref": "#/$defs/policy"},
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verbose": {"type": "boolean"},
        "print_performance_stats": {"type": "boolean"},
        "print_rebalance_log": {"type": "boolean"},
        "rebalance_log_tail": {"type": "integer", "minimum": 1},
        "save_performance_stats_json": {"type": "string"},
        "save_equity_curve_csv": {"type": "string"},
        "save_account_history_csv": {"type": "string"},
        "save_position_values_csv": {"type": "string"},
        "save_full_hold_benchmarks_csv": {"type": "string"},
        "save_rebalance_log_csv": {"type": "string"},
        "plot_equity_curve": {"type": "boolean"},
        "plot_trade_markers": {"type": "boolean"},
        "plot_full_hold_benchmarks": {"type": "boolean"},
        "full_hold_benchmark_tickers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "equity_curve_plot_path": {"type": "string"}
      }
    },
    "portfolio": {
      "type": "object",
      "required": ["cash"],
      "additionalProperties": false,
      "properties": {
        "cash": {"type": "number", "minimum": 0},
        "positions": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        }
      }
    }
  },
  "$defs": {
    "score_weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "c_over_ema200": {"type": "number"},
        "ema50_over_ema200": {"type": "number"},
        "mom_252_21": {"type": "number"},
        "vol_adjusted_momentum": {"type": "number"},
        "breakout55": {"type": "number"}
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_breadth": {"type": "boolean"},
        "breadth_min_frac": {"type": "number", "minimum": 0, "maximum": 1},
        "min_confirmations": {"type": "integer", "minimum": 1},
        "require_anchor_trend": {"type": "boolean"},
        "drawdown_lookback": {"type": "integer", "minimum": 1},
        "drawdown_floor": {"type": "number", "minimum": -1, "maximum": 0}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rebalance_freq": {"type": "string"},
        "target_vol_risk_on": {"type": "number"},
        "gross_cap_risk_on": {"type": "number"},
        "gross_cap_risk_off": {"type": "number"},
        "max_weight": {"type": "number"},
        "min_hold_days": {"type": "integer", "minimum": 0},
        "risk_off_target_vol_multiplier": {"type": "number"},
        "covariance_lookback": {"type": "integer", "minimum": 1},
        "liquidity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min_adv_dollars": {"type": "number", "minimum": 0},
            "max_trade_adv_fraction": {"type": "number", "minimum": 0}
          }
        },
        "risk_exit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stop_loss_pct": {"type": "number", "minimum": 0, "maximum": 1},
            "trailing_stop_pct": {"type": "number", "minimum": 0, "maximum": 1},
            "cooldown_days": {"type": "integer", "minimum": 0}
          }
        },
        "regime": {"$ref": "#/$defs/regime"},
        "score_weights": {"$ref": "#/$defs/score_weights"}
      }
    }
  }
}
