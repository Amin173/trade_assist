{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "trade_assist policy config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "rebalance_freq": {"type": "string"},
    "target_vol_risk_on": {"type": "number"},
    "gross_cap_risk_on": {"type": "number"},
    "gross_cap_risk_off": {"type": "number"},
    "max_weight": {"type": "number"},
    "min_hold_days": {"type": "integer", "minimum": 0},
    "min_trade_shares": {"type": "number", "minimum": 0},
    "risk_off_target_vol_multiplier": {"type": "number"},
    "covariance_lookback": {"type": "integer", "minimum": 1},
    "liquidity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_adv_dollars": {"type": "number", "minimum": 0},
        "max_trade_adv_fraction": {"type": "number", "minimum": 0}
      }
    },
    "risk_exit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stop_loss_pct": {"type": "number", "minimum": 0, "maximum": 1},
        "trailing_stop_pct": {"type": "number", "minimum": 0, "maximum": 1},
        "cooldown_days": {"type": "integer", "minimum": 0}
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_breadth": {"type": "boolean"},
        "breadth_min_frac": {"type": "number", "minimum": 0, "maximum": 1},
        "min_confirmations": {"type": "integer", "minimum": 1},
        "require_anchor_trend": {"type": "boolean"},
        "drawdown_lookback": {"type": "integer", "minimum": 1},
        "drawdown_floor": {"type": "number", "minimum": -1, "maximum": 0}
      }
    },
    "score_weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "c_over_ema200": {"type": "number"},
        "ema50_over_ema200": {"type": "number"},
        "mom_252_21": {"type": "number"},
        "vol_adjusted_momentum": {"type": "number"},
        "breakout55": {"type": "number"}
      }
    }
  }
}
